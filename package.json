{
  "name": "repo-pulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pay-per-call repo health score API, monetized with x402 on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.52.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "@x402/extensions": "^2.18.0",
    "@x402/hono": "^2.18.0",
    "hono": "^4.12.29",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
